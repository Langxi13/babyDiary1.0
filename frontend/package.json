{
  "name": "baby-diary-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "native:sync": "npm run build && cap sync",
    "native:android:sync": "npm run build && cap sync android",
    "native:android:build": "bash ../scripts/build-android.sh",
    "native:ios:sync": "npm run build && cap sync ios",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/camera": "8.2.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/ios": "8.4.1",
    "@capacitor/preferences": "8.0.1",
    "@element-plus/icons-vue": "^2.3.2",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/vue-3": "^3.27.3",
    "axios": "^1.18.1",
    "element-plus": "^2.14.2",
    "pinia": "^2.3.1",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/cli": "8.4.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "sass": "^1.101.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "glob": "13.0.6"
  }
}
