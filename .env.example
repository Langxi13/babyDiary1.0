# Database used by the application
DB_URL='jdbc:mysql://127.0.0.1:3306/baby-diary?serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true'
DB_USERNAME=baby_diary
DB_PASSWORD=replace-with-a-strong-database-password

# Only used by the local MySQL container
MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password

# Application runtime
DIARY_FILE_PATH=./data/images/
DIARY_PAGE_SIZE=5
INVITATION_CODE=replace-with-a-private-invitation-code
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=2592000000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
CACHE_PREFIX=baby-diary:local:

# Encrypts AI provider API keys stored in the database
AI_CONFIG_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
SLOW_REQUEST_THRESHOLD_MS=1000
