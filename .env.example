# MySQL
DB_URL='jdbc:mysql://127.0.0.1:3306/baby-diary?connectionTimeZone=%2B08:00&forceConnectionTimeZoneToSession=true&useSSL=false&allowPublicKeyRetrieval=true'
DB_USERNAME=baby_diary
DB_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password

# Application and authentication
DIARY_FILE_PATH=./data/images/
DIARY_OBJECT_PATH=./data/objects/
DIARY_PAGE_SIZE=5
INVITATION_CODE=replace-with-a-private-invitation-code
INVITATION_CODE_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=2592000000
JWT_ACCESS_EXPIRATION=900000
AUTH_REFRESH_DAYS=30
AUTH_SECURE_COOKIE=false
AUTH_STEP_UP_MINUTES=10
PUBLIC_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
CACHE_PREFIX=baby-diary:local:

# AI provider configuration encryption
AI_CONFIG_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Optional email delivery. Spring Boot reads the SPRING_MAIL_* variables directly.
MAIL_ENABLED=false
MAIL_FROM=
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Optional Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Rich media storage: local or s3
OBJECT_STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=baby-diary
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional media processing and OCR tools
MEDIA_PROCESSING_ENABLED=true
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
TESSERACT_BIN=tesseract
PDF_FONT_PATH=/usr/share/fonts/truetype/unifont/unifont.ttf

# Runtime tuning
REMINDER_DELIVERY_DELAY_MS=60000
SLOW_REQUEST_THRESHOLD_MS=1000
SPRINGDOC_ENABLED=true
